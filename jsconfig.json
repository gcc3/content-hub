{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@components/*": [
                "src/components/*"
            ],
            "@ui/*": [
                "src/ui/*"
            ],
            "@utils/*": [
                "src/utils/*"
            ],
            "@constants": [
                "src/constants.js"
            ]
        }
    },
    "include": [
        "src/**/*",
        "index.js"
    ]
}
